# Copia in `.env` per sviluppo locale. Vite espone solo variabili prefisso VITE_*
# La build di produzione (`npm run build`) usa invece `.env.production` committato (API HTTPS).

# Sviluppo locale (backend uvicorn su 8060)
VITE_API_BASE_URL=http://127.0.0.1:8060

# Produzione: già definito in `.env.production` — non serve duplicare qui salvo override manuale.
# VITE_API_BASE_URL=https://api.veterinariovicino.it
